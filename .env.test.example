# =============================================================================
# ArthaMind — Test Environment Configuration
# Used by CI/CD and local test runs.
# =============================================================================
ENVIRONMENT=test
DEBUG=false
LOG_LEVEL=warning

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=arthamind_test
POSTGRES_USER=arthamind_test
POSTGRES_PASSWORD=test_secret
DATABASE_URL=postgresql+asyncpg://arthamind_test:test_secret@localhost:5432/arthamind_test

REDIS_URL=redis://localhost:6379/1

SECRET_KEY=test_secret_key_minimum_32_chars_long
REFRESH_SECRET_KEY=test_refresh_secret_key_minimum_32_chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=5
REFRESH_TOKEN_EXPIRE_DAYS=1

GEMINI_API_KEY=test_api_key_not_real
GEMINI_MODEL=gemini-2.5-flash

CHROMADB_HOST=localhost
CHROMADB_PORT=8001

SEED_DATABASE=false
