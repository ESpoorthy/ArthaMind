# =============================================================================
# ArthaMind AI Banking Simulator — Environment Configuration Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
ENVIRONMENT=development           # development | staging | production
APP_NAME=ArthaMind
APP_VERSION=1.0.0
DEBUG=true                        # Set false in production
LOG_LEVEL=info                    # debug | info | warning | error | critical

# -----------------------------------------------------------------------------
# Backend API
# -----------------------------------------------------------------------------
BACKEND_PORT=8000
BACKEND_HOST=0.0.0.0
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------
FRONTEND_PORT=5173
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_BASE_URL=ws://localhost:8000
VITE_APP_NAME=ArthaMind
VITE_APP_VERSION=1.0.0

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=arthamind
POSTGRES_USER=arthamind
POSTGRES_PASSWORD=change_me_in_production
DATABASE_URL=postgresql+asyncpg://arthamind:change_me_in_production@localhost:5432/arthamind

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change_me_in_production
REDIS_URL=redis://:change_me_in_production@localhost:6379/0
REDIS_TTL_SECONDS=3600

# -----------------------------------------------------------------------------
# ChromaDB (Vector Database for RAG)
# -----------------------------------------------------------------------------
CHROMADB_HOST=localhost
CHROMADB_PORT=8001
CHROMADB_COLLECTION_NAME=arthamind_banking_kb

# -----------------------------------------------------------------------------
# JWT Authentication
# -----------------------------------------------------------------------------
SECRET_KEY=REPLACE_WITH_64_CHAR_RANDOM_SECRET
REFRESH_SECRET_KEY=REPLACE_WITH_ANOTHER_64_CHAR_RANDOM_SECRET
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# -----------------------------------------------------------------------------
# Google Gemini AI (LLM)
# -----------------------------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MAX_TOKENS=8192
GEMINI_TEMPERATURE=0.2

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
ENCRYPTION_KEY=REPLACE_WITH_32_BYTE_BASE64_KEY
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCKOUT_MINUTES=30
BCRYPT_ROUNDS=12

# -----------------------------------------------------------------------------
# OCR
# -----------------------------------------------------------------------------
TESSERACT_CMD=/usr/bin/tesseract
OCR_CONFIDENCE_THRESHOLD=0.7
MAX_UPLOAD_SIZE_MB=10
ALLOWED_UPLOAD_TYPES=image/jpeg,image/png,application/pdf

# -----------------------------------------------------------------------------
# Demo Accounts (Simulator)
# -----------------------------------------------------------------------------
DEMO_CUSTOMER_PASSWORD=Demo@12345
SEED_DATABASE=true
