{
  "name": "arthamind",
  "version": "1.0.0",
  "description": "ArthaMind AI Banking Simulator - A comprehensive AI-powered banking platform with multi-agent architecture",
  "private": true,
  "workspaces": [
    "frontend",
    "shared"
  ],
  "scripts": {
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:backend": "cd backend && uvicorn src.main:app --reload --port 8000",
    "build:frontend": "npm run build --workspace=frontend",
    "build:shared": "npm run build --workspace=shared",
    "test:frontend": "npm run test --workspace=frontend",
    "test:backend": "cd backend && python -m pytest tests/ -v",
    "lint:frontend": "npm run lint --workspace=frontend",
    "format": "prettier --write \"frontend/src/**/*.{ts,tsx}\" \"shared/src/**/*.ts\"",
    "prepare": "husky install"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "husky": "^8.0.3",
    "lint-staged": "^15.2.2",
    "prettier": "^3.2.5",
    "typescript": "^5.3.3"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
